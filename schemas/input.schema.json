{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BARE Input Format v1",
  "description": "findings.json document consumed by BARE — see INPUT_FORMAT.md",
  "type": "object",
  "required": ["version", "source", "findings"],
  "additionalProperties": true,
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "description"],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "target": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "pattern": "^(?:[Ii][Nn][Ff][Oo]|[Ll][Oo][Ww]|[Mm][Ee][Dd][Ii][Uu][Mm]|[Hh][Ii][Gg][Hh]|[Cc][Rr][Ii][Tt][Ii][Cc][Aa][Ll])$"
          },
          "metadata": {
            "type": "object"
          }
        }
      }
    }
  }
}
