{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BARE Output Format v1",
  "description": "Ranked module results emitted by BARE — see OUTPUT_FORMAT.md",
  "type": "object",
  "required": ["version", "source", "corpus", "findings"],
  "additionalProperties": true,
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "source": {
      "type": "string",
      "const": "bare"
    },
    "corpus": {
      "type": "object",
      "required": ["size", "sha256"],
      "additionalProperties": false,
      "properties": {
        "size": {
          "type": "integer",
          "minimum": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "matches"],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "target": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          },
          "matches": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["rank", "module", "score", "category"],
              "additionalProperties": false,
              "properties": {
                "rank": {
                  "type": "integer",
                  "minimum": 1
                },
                "module": {
                  "type": "string",
                  "minLength": 1
                },
                "score": {
                  "type": "number",
                  "minimum": 0.0,
                  "maximum": 1.0
                },
                "category": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    }
  }
}
